{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://egoknowledge.local/schemas/dossier.schema.json",
  "type": "object",
  "required": [
    "reviewed_at",
    "review_due_at",
    "evidence_refs"
  ],
  "properties": {
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "review_due_at": {
      "type": "string",
      "format": "date"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
